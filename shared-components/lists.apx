list application-actions (
    name: Thao tác ứng dụng

    entry administration (
        label: Quản trị
        icon {
            imageIconCssClasses: fa-user
        }
        layout {
            sequence: 80
        }
        link {
            target: {
                page: 4
            }
        }
        userDefinedAttributes {
            1: Run reports to analyze sales history data.
        }
    )

    entry analysis-reports (
        label: Báo cáo phân tích
        icon {
            imageIconCssClasses: fa-file-o
        }
        layout {
            sequence: 70
        }
        link {
            target: {
                page: 19
            }
        }
        userDefinedAttributes {
            1: Run reports to analyze sales history data.
        }
    )

    entry generate-transactions (
        label: Tạo giao dịch
        icon {
            imageIconCssClasses: fa-gears
        }
        layout {
            sequence: 60
        }
        link {
            target: {
                page: 28
            }
        }
        userDefinedAttributes {
            1: Generate sale transactions
        }
    )

    entry products (
        label: Sản phẩm
        icon {
            imageIconCssClasses: fa-package
        }
        layout {
            sequence: 50
        }
        link {
            target: {
                page: 11
                action: resetPagination
            }
        }
        userDefinedAttributes {
            1: Identify product items available for sale at one or more stores
        }
    )

    entry regions (
        label: Khu vực
        icon {
            imageIconCssClasses: fa-globe
        }
        layout {
            sequence: 30
        }
        link {
            target: {
                page: 8
                action: resetPagination
            }
        }
        userDefinedAttributes {
            1: Each store is mapped to a geographic region
        }
    )

    entry sales-dashboard (
        label: Bảng điều khiển doanh số
        icon {
            imageIconCssClasses: fa-line-chart
        }
        layout {
            sequence: 10
        }
        link {
            target: {
                page: 5
                action: resetPagination
            }
        }
        userDefinedAttributes {
            1: Analysis dashboard of sales data.
        }
    )

    entry sales-history (
        label: Lịch sử doanh số
        icon {
            imageIconCssClasses: fa-credit-card
        }
        layout {
            sequence: 56
        }
        link {
            target: {
                page: 51
                clearCache: 51
                action: resetPagination
            }
        }
        userDefinedAttributes {
            1: Identify product items available for sale at one or more stores
        }
    )

    entry stores (
        label: Cửa hàng
        icon {
            imageIconCssClasses: fa-shopping-bag
        }
        layout {
            sequence: 40
        }
        link {
            target: {
                page: 6
            }
        }
        userDefinedAttributes {
            1: Identify attributes, products sold, discounts and geographic region
        }
    )

)

list navigation-bar (
    name: Thanh điều hướng

    entry app-user (
        label: &APP_USER.
        icon {
            imageIconCssClasses: a-Icon icon-user
        }
        layout {
            sequence: 20
        }
        link {
            target: {
                type: url
                url: #
            }
        }
        userDefinedAttributes {
            2: has-username
        }
    )

    entry install-app (
        label: Cài đặt ứng dụng
        icon {
            imageIconCssClasses: fa-cloud-download
        }
        layout {
            sequence: 1
        }
        isCurrent {
            type: never
        }
        link {
            target: {
                type: url
                url: #action$a-pwa-install
            }
        }
        userDefinedAttributes {
            2: a-pwaInstall
        }
    )

    entry sign-out (
        label: Đăng xuất
        layout {
            sequence: 30
            parentEntry: @app-user
        }
        link {
            target: {
                type: url
                url: &LOGOUT_URL.
            }
        }
    )

)

