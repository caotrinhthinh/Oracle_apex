list reports (
    name: reports

    entry products-available-by-store (
        label: Sản phẩm khả dụng theo cửa hàng
        icon {
            imageIconCssClasses: fa-archive
        }
        layout {
            sequence: 60
        }
        link {
            target: {
                page: 27
                action: resetPagination
            }
        }
        userDefinedAttributes {
            1: View percentages of products available at each store
            2: reportIcon
        }
    )

    entry sales-by-product-and-region-by-week (
        label: Doanh số theo sản phẩm và khu vực theo tuần
        icon {
            imageIconCssClasses: fa-dollar
        }
        layout {
            sequence: 40
        }
        link {
            target: {
                page: 25
                action: resetPagination
            }
        }
        userDefinedAttributes {
            1: Interactive report of weekly sales metrics by product by region
            2: reportIcon
        }
    )

    entry sales-by-region-by-week (
        label: Doanh số theo khu vực theo tuần
        icon {
            imageIconCssClasses: fa-dollar
        }
        layout {
            sequence: 30
        }
        link {
            target: {
                page: 22
                action: resetPagination
            }
        }
        userDefinedAttributes {
            1: Weekly sales metrics by region
            2: reportIcon
        }
    )

    entry sales-by-store-by-day (
        label: Doanh số theo cửa hàng theo ngày
        icon {
            imageIconCssClasses: fa-calendar
        }
        layout {
            sequence: 50
        }
        link {
            target: {
                page: 20
                action: resetPagination
            }
        }
        userDefinedAttributes {
            1: View monthly calendar of sales by store by day
            2: calendarIcon
        }
    )

    entry table-row-counts (
        label: Số lượng dòng bảng
        icon {
            imageIconCssClasses: fa-table
        }
        layout {
            sequence: 90
        }
        link {
            target: {
                page: 32
                action: resetPagination
            }
        }
        userDefinedAttributes {
            1: View a list of the database tables used by this demonstration system and the current row counts.
            2: reportIcon
        }
    )

)

list reset-sample-data-list (
    name: Danh sách đặt lại dữ liệu mẫu

    entry reset-data-to-2xl (
        label: Đặt lại dữ liệu mức 2XL
        icon {
            imageIconCssClasses: fa-cog
        }
        layout {
            sequence: 50
        }
        link {
            target: {
                type: url
                url: javascript:$s('P40_SIZE','XXL');apex.submit({showWait:true});
            }
        }
        userDefinedAttributes {
            1: Truncate existing sales history data and generate 50,000 rows of sales history
        }
    )

    entry reset-data-to-3xl (
        label: Đặt lại dữ liệu mức 3XL
        icon {
            imageIconCssClasses: fa-cog
